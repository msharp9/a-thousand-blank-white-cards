# REST API base URL (no trailing slash)
# local:  http://localhost:8000
# prod:   https://tbwc-backend.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL (ws:// local, wss:// prod)
# local:  ws://localhost:8000
# prod:   wss://tbwc-backend.onrender.com
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Dev-only UI (e.g. the Dynamic game state panel). Also auto-enabled when
# NODE_ENV=development (e.g. `next dev`); set true to force it on in a
# production build for debugging.
# NEXT_PUBLIC_DEV_MODE=false
