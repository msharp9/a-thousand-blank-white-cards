# PyCharm
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
.idea/

# IDE specific ignore files
.vscode

# Nano lockfiles
.*.swp

# Embedding content-hash cache (disk-backed, rebuilt on demand)
.embedding_cache.json

# Data
output/
data/*
datasets/
plan/
# ...but keep the curated gold seed card corpus
!data/seed_cards_gold.json
!data/seed_cards_fillers.json
!data/seed_cards.json
!data/seed_cards_simple.json
# ...and keep the eval corpus tooling and annotations
!data/eval/
!data/eval/**
# ...but never track caches under the eval dir
data/eval/**/__pycache__/
data/eval/**/*.pyc
# ...and never track the downloaded card-photo dataset (large binaries).
# The images are fetched on demand via data/eval/download_images.py; only the
# manifest is kept so downstream tooling can join URLs -> local filenames.
data/eval/images/*
!data/eval/images/manifest.json

# Models (ML artifact dirs) — but NOT the src/models Python source package.
# The negation must match the current flat src/ layout; the old src/tbwc/models/
# path was flattened away, and hatch honors this ignore at build time (it dropped
# src/models from the wheel while the stale negation pointed at the dead path).
models/
!src/models/

# Dev-only FileRoomStore persistence (dev_mode room snapshots)
.devstate/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Frontend (Next.js) build/deps safety net
frontend/node_modules/
frontend/.next/

# dmux worktree orchestration artifacts (local tooling, not project code)
.dmux/
.dmux-hooks/
.claude/dmux/
.claude/hooks/dmux-stop-hook.cjs
.worktrees/

# Claude Code agent worktrees (local orchestration, not project code)
.claude/worktrees/

dev_notes/
