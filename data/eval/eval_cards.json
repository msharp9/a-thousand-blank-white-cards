  {
    "title": "Most Cards Drawn Wins",
    "description": "End the game. Whoever has drawn the most cards wins; ties share the win.",
    "human_canonical": {
      "timing": "immediate",
      "target": "all",
      "placement": "discard",
      "trigger_event": "on_play",
      "magnitude_sign": "neutral",
      "steps": [
        {"kind": "snippet", "code": "def apply(state, ctx):\n    totals = state.draw_totals()\n    best = max(totals.values())\n    state.end_game(['id:' + pid for pid, total in totals.items() if total == best])\n"}
      ]
    }
  },
