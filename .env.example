# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real secrets.

# LLM gateway (generic, OpenAI-compatible). ONE base_url + api_key + model set
# drives BOTH chat and embeddings. Point it at any OpenAI-compatible endpoint.
#
# Three example configurations:
#
#   1) Hosted OpenAI (default): leave LLM_BASE_URL blank, set a real key.
#        LLM_BASE_URL=
#        LLM_API_KEY=sk-...
#
#   2) Company gateway (e.g. bifrost): full URL + gateway key. The key doubles as
#      bifrost's virtual key — it's mirrored into the x-bf-vk header automatically,
#      so there's nothing extra to set.
#        LLM_BASE_URL=https://gateway.example.com/openai
#        LLM_API_KEY=<gateway-key>
#
#   3) Local Ollama (OpenAI-compatible, keyless — saves tokens):
#        LLM_BASE_URL=http://localhost:11434/v1
#        LLM_API_KEY=ollama
#        LLM_CHAT_MODEL=gpt-oss-20b
#        LLM_EMBEDDING_MODEL=nomic-embed-text
#        LLM_EMBEDDING_DIMENSIONS=768

# Base URL of the OpenAI-compatible endpoint. Blank = hosted OpenAI's default.
LLM_BASE_URL=
# API key. Blank is allowed for keyless local gateways; a non-empty placeholder is
# supplied to the client automatically. Hosted OpenAI (blank base URL) needs a real key.
LLM_API_KEY=sk-...
LLM_CHAT_MODEL=gpt-5.4-mini
LLM_EMBEDDING_MODEL=text-embedding-3-small
# Vector size of the embedding model (text-embedding-3-small = 1536). Feeds the
# Qdrant collection dimension — MUST match the model (nomic-embed-text = 768).
LLM_EMBEDDING_DIMENSIONS=1536
# Vision (optional): attach a card's hand-drawn PNG to the arbiter's model input
# as an image so drawings influence interpretation. Requires LLM_CHAT_MODEL to
# accept image input; if the model rejects images the play retries text-only.
VISION_ENABLED=false

# LangSmith observability (optional — set LANGSMITH_TRACING=true to enable)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=tbwc-dev
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# Legacy aliases (old names for the same settings) — only needed for older setups;
# if a LANGSMITH_* value above is unset, the matching LANGCHAIN_* var below fills it:
#   LANGCHAIN_TRACING_V2 -> LANGSMITH_TRACING
#   LANGCHAIN_API_KEY    -> LANGSMITH_API_KEY
#   LANGCHAIN_PROJECT    -> LANGSMITH_PROJECT

# Tavily (used by agent web-search tool)
TAVILY_API_KEY=tvly-...

# Qdrant (local Docker default — change for cloud)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=tbwc_cards

# Server
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
HOST=0.0.0.0
PORT=8000

# Sandbox (set to false on restricted hosts to skip subprocess snippet execution)
SNIPPET_EXECUTION_ENABLED=true

# Failure triage agent — when a played card fails to execute or no-ops, an
# async (fire-and-forget, non-blocking) agent diagnoses why and appends a
# capability "wish" for human review. On by default; set false to disable.
TRIAGE_AGENT_ENABLED=true
# Blank = use LLM_CHAT_MODEL (above). Set to triage on a different/cheaper model.
TRIAGE_AGENT_MODEL=
# Max concurrent triage LLM calls across all rooms.
TRIAGE_AGENT_MAX_CONCURRENCY=2
# Per-report time budget (seconds).
TRIAGE_AGENT_TIMEOUT_SECONDS=30.0
# One report per (card, failure-kind) per room session.
TRIAGE_AGENT_DEDUPE=true
# Where triage appends capability wishes (JSONL). Point at a persistent volume
# in production and export it for human review.
CAPABILITY_WISH_PATH=.devstate/capability_wishes.jsonl

# enable dev-loop features: room persistence + /dev endpoints
DEV_MODE=false  
