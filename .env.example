# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real secrets.

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# LangSmith (optional — set LANGCHAIN_TRACING_V2=true to enable)
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=tbwc
LANGCHAIN_TRACING_V2=false

# LangSmith observability (newer LANGSMITH_* convention)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=tbwc-dev
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Tavily (used by agent web-search tool)
TAVILY_API_KEY=tvly-...

# Qdrant (local Docker default — change for cloud)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=tbwc_cards

# Server
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
HOST=0.0.0.0
PORT=8000

# Sandbox (set to false on restricted hosts to skip subprocess snippet execution)
SNIPPET_EXECUTION_ENABLED=true
