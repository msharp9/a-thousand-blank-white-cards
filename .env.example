# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real secrets.

# LLM provider: "openai" (hosted, default) or "ollama" (local, saves tokens).
# When set to "ollama", chat + embeddings hit a local OpenAI-compatible server
# (see the Ollama block below) and OPENAI_API_KEY is NOT required at startup.
LLM_PROVIDER=openai

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Vector size of the OpenAI embedding model (text-embedding-3-small = 1536).
# Feeds the Qdrant collection dimension — must match the model.
OPENAI_EMBEDDING_DIMENSIONS=1536

# Ollama (local, OpenAI-compatible API — only used when LLM_PROVIDER=ollama).
# The server accepts a dummy api key; a placeholder is supplied automatically.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_CHAT_MODEL=gpt-oss-20b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# Ollama embedding dims DIFFER from OpenAI (nomic-embed-text = 768, not 1536).
# The Qdrant collection is created with whichever provider's dimension is active.
OLLAMA_EMBEDDING_DIMENSIONS=768

# Optional: structured-output method for LangChain .with_structured_output().
# Empty = library default (OpenAI tool-calling). gpt-oss-20b via Ollama may need
# "json_schema" for reliable typed output — tool-calling can be unreliable there.
STRUCTURED_OUTPUT_METHOD=

# LangSmith observability (optional — set LANGSMITH_TRACING=true to enable)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=tbwc-dev
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# Legacy aliases (old names for the same settings) — only needed for older setups;
# if a LANGSMITH_* value above is unset, the matching LANGCHAIN_* var below fills it:
#   LANGCHAIN_TRACING_V2 -> LANGSMITH_TRACING
#   LANGCHAIN_API_KEY    -> LANGSMITH_API_KEY
#   LANGCHAIN_PROJECT    -> LANGSMITH_PROJECT

# Tavily (used by agent web-search tool)
TAVILY_API_KEY=tvly-...

# Qdrant (local Docker default — change for cloud)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=tbwc_cards

# Server
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
HOST=0.0.0.0
PORT=8000

# Sandbox (set to false on restricted hosts to skip subprocess snippet execution)
SNIPPET_EXECUTION_ENABLED=true
